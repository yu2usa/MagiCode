  entries:
  - keyword: "-\u95A2\u6570-"
    description: 
  - keyword: "\u95A2\u6570: Cast()"
    description: "<b>[AP\u6D88\u8CBB: 20] [\u30C0\u30E1\u30FC\u30B8: 4]</b> \n<b>Cast(\"\u9B54\u6CD5\u7A2E\u985E\",
      n) </b>\n\u4E0A\u8A18\u306E\u3088\u3046\u306B\u3001\u9B54\u6CD5\u306E\u7A2E\u985E\u3068n(\u653B\u6483\u3059\u308B\u30A8\u30EA\u30A2\u756A\u53F7)\u3092\u6307\u5B9A\u3059\u308C\u3070\u305D\u306E\u30A8\u30EA\u30A2\u306B\u4EFB\u610F\u306E\u9B54\u6CD5\u3092\u3046\u3064\u3053\u3068\u304C\u3067\u304D\u308B\u3002\n\u9B54\u6CD5\u306E\u7A2E\u985E\u3068\u3057\u3066\u4EE5\u4E0B\u304C\u5B58\u5728\u3059\u308B:\n<b>
      \n\u30FB\u30D5\u30EC\u30A4\u30E0\n\u30FB\u30D5\u30EA\u30FC\u30BA\n\u30FB\u30E9\u30A4\u30C8\u30CB\u30F3\u30B0\n</b>"
  - keyword: "\u95A2\u6570: Attack()"
    description: "<b>[AP\u6D88\u8CBB: 10] [\u30C0\u30E1\u30FC\u30B8: 3]</b>\n\u30B7\u30F3\u30D7\u30EB\u306A\u8FD1\u63A5\u653B\u6483\u3002\u540C\u30A8\u30EA\u30A2\u306E\u6575\u306B\u5BFE\u3057\u3066\u30C0\u30E1\u30FC\u30B8\u3092\u4E0E\u3048\u308B\u3002"
  - keyword: "\u95A2\u6570: MoveForward()"
    description: "\u9632\u5FA1\u30D5\u30A7\u30FC\u30BA\u3067\u306E\u307F\u4F7F\u3048\u308B\u3002\u30D7\u30EC\u30A4\u30E4\u30FC\u306E\u5411\u3044\u3066\u3044\u308B\u30A8\u30EA\u30A2\u3078\u79FB\u52D5\u3059\u308B\u3002"
  - keyword: "\u95A2\u6570: MoveBackward()"
    description: "\u9632\u5FA1\u30D5\u30A7\u30FC\u30BA\u3067\u306E\u307F\u3067\u4F7F\u3048\u308B\u3002\u30D7\u30EC\u30A4\u30E4\u30FC\u306E1\u3064\u5F8C\u308D\u306E\u30A8\u30EA\u30A2\u3078\u79FB\u52D5\u3059\u308B\u3002"
  - keyword: "-\u7E70\u308A\u8FD4\u3057-"
    description: 
  - keyword: "\u7E70\u308A\u8FD4\u3057:  for i in range(n):"
    description: "\u3053\u306E\u30B3\u30FC\u30C9\u306E1\u3064\u4E0B\u306E\u884C\u3067\u3001\u534A\u89D2\u30B9\u30DA\u30FC\u30B94\u6587\u5B57(\u30A4\u30F3\u30C7\u30F3\u30C8)\u3092\u3057\u3066\u3001\u7E70\u308A\u8FD4\u3057\u305F\u3044\u95A2\u6570\u3092\u5165\u529B\u3059\u308B\u3068\u3001n-1\u56DE\u7E70\u308A\u8FD4\u3059\u3053\u3068\u304C\u3067\u304D\u308B\u3002\n\u3057\u304B\u3082\u3002\u521D\u56DE\u306E\u7E70\u308A\u8FD4\u3057\u5185\u5BB9\u306F\u3001<b>AP\u306E\u6D88\u8CBB\u3092\u534A\u6E1B</b>\u3067\u304D\u308B!"
  - keyword: "-\u6761\u4EF6\u5206\u5C90-"
    description: 
  - keyword: "\u6761\u4EF6\u5206\u5C90: if(): "
    description: "\u5909\u6570\u306E\u72B6\u614B\u3092\u8ABF\u3079\u305F\u308A\u3001\u6575\u306E\u72B6\u614B\u3092\u8ABF\u3079\u3001\u305D\u306E\u7D50\u679C\u306B\u5FDC\u3058\u3066\u884C\u52D5\u3092\u5909\u3048\u308B\u3053\u3068\u304C\u3067\u304D\u308B\u3002\n\u6575\u306E\u5C5E\u6027\u3092\u8ABF\u3079\u308B\u306B\u306F\u3001\u4EE5\u4E0B\u306E\u3088\u3046\u306A\u30B3\u30FC\u30C9\u3092\u5165\u529B\u3059\u308B\u3002(\u5C5E\u6027\u306B\u306F\u3001\u30D5\u30EC\u30A4\u30E0,
      \u30A2\u30A4\u30B9\u304C\u3042\u308B\u3002)\n<b>if(enemy['element'] == \"\u5C5E\u6027\"):</b> "
  - keyword: "\u5909\u6570"
    description: "\u5909\u6570\u3068\u306F\u3001\u4E2D\u8EAB\u3092\u81EA\u7531\u306B\u5909\u3048\u3089\u308C\u308B\u6570\u306E\u3053\u3068\u3060\u3002\n\u7E70\u308A\u8FD4\u3057\u6587\u306E\u4E2D\u306B\u5909\u6570\u3092\u5165\u308C\u305F\u308A\u3001\u8272\u3005\u306A\u5834\u9762\u3067\u4F7F\u3048\u308B\u305E\u3002\n\u4F8B:
      \nfor i in range(n): \n\u4E0A\u8A18\u306E\u5834\u5408\u306F\u3001n\u56DE\u7E70\u308A\u8FD4\u3059\u30B3\u30FC\u30C9\u3001\u3068\u3044\u3046\u3053\u3068\u306B\u306A\u308B\u305E!"
  - keyword: "\u914D\u5217"
    description: "\u914D\u5217\u306F\u3001\u8907\u6570\u306E\u8981\u7D20(\u6570\u3084\u6587\u5B57\u5217\u306A\u3069)\u3092\u307E\u3068\u3081\u305F\u3082\u306E\u3067\u3001\n<b>\u914D\u5217\u540D
      = [\u8981\u7D201, \u8981\u7D202, \u8981\u7D203]</b>\n\u306E\u3088\u3046\u306B\u8A18\u8FF0\u3059\u308B\u305E\u3002\n\u305D\u3057\u3066\u3001<b>\u914D\u5217\u540D[n]</b>\u3068\u66F8\u304F\u3068\u3001\u305D\u306E\u914D\u5217\u304B\u3089n\u756A\u76EE\u306E\u8981\u7D20\u3092\u53D6\u5F97\u3067\u304D\u308B!
      \n\u307E\u305F\u3001<b>len(\u914D\u5217\u540D) </b>\n\u3068\u66F8\u304F\u3053\u3068\u3067\u305D\u306E\u914D\u5217\u306E\u8981\u7D20\u306E\u6570\u3092\u53D6\u5F97\u3067\u304D\u308B!\n<b>\u3061\u306A\u307F\u306B\u3001\u914D\u5217\u306E\u8981\u7D20\u306F0\u304B\u3089\u30AB\u30A6\u30F3\u30C8\u3057\u3066\u3044\u304F\u305E\u3002</b>"
  - keyword: "\u914D\u5217\u8981\u7D20\u5165\u308C\u66FF\u3048: Swap()"
    description: "<b>[\u540C\u3058\u30B3\u30FC\u30C9\u4E2D\u306BSwap()\u306F1\u56DE\u3057\u304B\u66F8\u3051\u306A\u3044]</b>\n\u76F4\u524D\u306B\u66F8\u3044\u305F\u914D\u5217\u306E\u8981\u7D20\u3068\u8981\u7D20\u3092\u5165\u308C\u66FF\u3048\u308B\u3053\u3068\u304C\u3067\u304D\u308B\u95A2\u6570\u3060\u3002\n<b>\u914D\u5217\u540D
      = [\u8981\u7D201, \u8981\u7D202, \u8981\u7D203]</b>\n<b>Swap(0, 1)</b>\n\u3068\u66F8\u304F\u3068\u30010\u756A\u76EE\u306E\u8981\u7D20\u30681\u756A\u76EE\u306E\u8981\u7D20\u3092\u5165\u308C\u66FF\u3048\u308B\u3001\u3068\u3044\u3046\u610F\u5473\u306B\u306A\u308A\u3001\n<b>\u914D\u5217\u540D
      = [\u8981\u7D202, \u8981\u7D201, \u8981\u7D203]</b>\n\u3068\u3044\u3046\u3088\u3046\u306B\u4E26\u3073\u66FF\u3048\u3089\u308C\u308B\u305E!"
