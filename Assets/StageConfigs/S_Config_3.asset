    changeVisibility: 1
    showPlayer: 1
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 1
    text: "\u30B3\u30FC\u30C9\u3092\u898B\u3064\u3051\u307E\u3057\u305F\u3002\n\u3069\u3046\u3084\u3089\u300C\u6761\u4EF6\u5206\u5C90\u300D\u3068\u3044\u3046\u7A2E\u985E\u306E\u30B3\u30FC\u30C9\u3067\u3001\u8272\u3005\u306A\u3082\u306E\u306E\u72B6\u614B\u3092\u5224\u5B9A\u3057\u3066\u3001\u884C\u52D5\u3092\u5909\u3048\u3089\u308C\u308B\u3088\u3046\u3067\u3059\u3002"
    bounce: 1
    changeVisibility: 1
    showPlayer: 1
    showAssistant: 1
    showEnemy: 0
    enemyIndex: 0
  - speaker: 0
    text: "\u306A\u308B\u307B\u3069\u3001\u8272\u3005\u306A\u3053\u3068\u306B\u4F7F\u3048\u305D\u3046\u3060\u306D\u3002\u3063\u3066\u3001\u5965\u304B\u3089\u8AB0\u304B\u6765\u3066\u308B!"
    bounce: 0
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 2
    text: "\u79C1\u306F\u30A8\u30EC\u30E1\u30F3\u30BF\u30EB\u30FB\u30A6\u30A3\u30B6\u30FC\u30C9!!"
    bounce: 1
    changeVisibility: 1
    showPlayer: 1
    showAssistant: 1
    showEnemy: 1
    enemyIndex: 0
  - speaker: 2
    text: "\u79C1\u306F\u540C\u5C5E\u6027\u3057\u304B\u53D7\u3051\u4ED8\u3051\u306A\u3044\u3001\u9244\u58C1\u306E\u5B88\u308A\u3092\u6301\u3063\u3066\u3044\u308B!!\n\u5F53\u3066\u3089\u308C\u308B\u3082\u3093\u306A\u3089\u5F53\u3066\u3066\u307F\u308D!"
    bounce: 1
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 1
    text: "\u3053\u308C\u307E\u3067\u306E\u30B3\u30FC\u30C9\u30A8\u30CD\u30DF\u30FC\u3088\u308A\u3082\u6570\u6BB5\u5384\u4ECB\u305D\u3046\u3067\u3059\u3002\u5FC3\u3057\u3066\u6226\u3044\u307E\u3057\u3087\u3046\u3002"
