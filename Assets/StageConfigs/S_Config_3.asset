  bgmClip: {fileID: 8300000, guid: 8d877c1f8d39d6145a86ef68cf686913, type: 3}
  introDialogue:
  - speaker: 0
    text: "\u3055\u3089\u306B\u5965\u306B\u6765\u305F\u3051\u3069\u3001\u3069\u3093\u306A\u30B3\u30FC\u30C9\u304C\u3042\u308B\u3093\u3060\u308D\u3046.."
