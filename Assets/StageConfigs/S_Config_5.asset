  bgmClip: {fileID: 8300000, guid: b96f52b31da5c7042a82ef15b8462c69, type: 3}
  introDialogue:
  - speaker: 0
    text: "\u3042\u308C\u304C\u65E7\u6587\u660E\u306E\u30B3\u30A2..\u771F\u3063\u8D64\u306B\u5149\u3063\u3066\u308B\u3002"
    bounce: 0
    changeVisibility: 1
    showPlayer: 1
    showAssistant: 1
    showEnemy: 1
    enemyIndex: 0
  - speaker: 0
    text: "\u305D\u3046\u3044\u3048\u3070\u3001\u3053\u3053\u306B\u6765\u308B\u307E\u3067\u306B\u906D\u9047\u3057\u305F\u30B3\u30FC\u30C9\u30A8\u30CD\u30DF\u30FC\u3082\u3001\u5168\u54E1\u8D64\u3063\u307D\u304F\u306A\u3063\u3066\u305F\u3088\u3046\u306A.."
    bounce: 0
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 1
    text: "\u304A\u305D\u3089\u304F\u3001\u3042\u306E\u30B3\u30A2\u306E\u524D\u306B\u3042\u308B\u6570\u5B57\u304C\u539F\u56E0\u3067\u3057\u3087\u3046\u3002\u3042\u306E\u6570\u5B57\u306E\u4E26\u3073\u304C\u3050\u3061\u3083\u3050\u3061\u3083\u306B\u306A\u3063\u3066\u3044\u308B\u307F\u305F\u3044\u3067\u3059\u3002\u672C\u6765\u306F\u6607\u9806\u306B\u4E26\u3093\u3067\u3044\u306A\u3044\u3068\u3044\u3051\u306A\u3044\u6570\u5B57\u306B\u898B\u3048\u307E\u3059\u3002"
    bounce: 0
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 1
    text: "\u3067\u3042\u308C\u3070\u3001\u3055\u304D\u307B\u3069\u898B\u3064\u3051\u305F\u3053\u306E\u30B3\u30FC\u30C9\u304C\u4F7F\u3048\u305D\u3046\u3067\u3059\u306D\u3002"
    bounce: 0
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 0
    text: "\u3063\u3066..\u5371\u306A\u3044! \u30B3\u30A2\u304C\u30D3\u30FC\u30E0\u6483\u3063\u3066\u304D\u305F!!\n\u65E9\u304F\u30B3\u30A2\u3092\u5143\u901A\u308A\u306B\u3057\u3088\u3046!"
