  stageDescription: "\u304B\u3064\u3066\u4EBA\u3005\u306F\u30B3\u30FC\u30C9\u3092\u66F8\u304D\u3001\u9AD8\u5EA6\u306A\u6587\u660E\u3092\u7BC9\u3044\u305F\u3002\n\u3057\u304B\u3057\u3001\u6587\u660E\u3092\u7BA1\u7406\u3057\u3066\u3044\u305F\u30B7\u30B9\u30C6\u30E0\u306E\u66B4\u8D70\u306B\u3088\u308A\u3001\u6587\u660E\u306F\u5D29\u58CA\u3057\u3066\u3057\u307E\u3063\u305F\u3002\n\u3042\u306A\u305F\u306F\u552F\u4E00\u30B3\u30FC\u30C9\u306E\u8AAD\u3081\u308B\u4EBA\u9593\u3068\u3057\u3066\u3001\u4EBA\u5DE5\u77E5\u80FD\u306E\u30C6\u30E9\u3068\u5171\u306B\u30B3\u30FC\u30C9\u3092\u96C6\u3081\u308B\u3053\u3068\u3068\u306A\u3063\u305F!"
