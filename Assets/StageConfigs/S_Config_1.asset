  introDialogue:
  - speaker: 1
    text: "\u3053\u3053\u304C\u3001\u521D\u3081\u3066\u306E\u30B3\u30FC\u30C9\u300C\u95A2\u6570\u300D\u304C\u3042\u308B\u5834\u6240\u3067\u3059\u3002"
    bounce: 0
    changeVisibility: 1
    showPlayer: 1
    showAssistant: 1
    showEnemy: 0
    enemyIndex: 0
  - speaker: 1
    text: "\u95A2\u6570\u306F\u3001\u300C\u95A2\u6570\u540D()\u300D\u3068\u66F8\u304F\u3053\u3068\u3067\u3001\u305D\u306E\u95A2\u6570\u306E\u884C\u52D5\u3092\u5B9F\u884C\u3067\u304D\u307E\u3059\u3002"
    bounce: 0
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 0
    text: "\u3053\u308C\u304C\u95A2\u6570..\u30B3\u30FC\u30C9\u3063\u3066\u9577\u3044\u96E3\u3057\u3044\u30A4\u30E1\u30FC\u30B8\u304C\u3042\u3063\u305F\u3093\u3060\u3051\u3069\u3001\u3053\u308C\u306F\u77ED\u3044\u306D\u3002"
    bounce: 0
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 1
    text: "\u305D\u3046\u3067\u3059\u3002\u591A\u304F\u306E\u30B3\u30FC\u30C9\u306F\u307E\u305A\u3053\u306E\u30B7\u30F3\u30D7\u30EB\u306A\u95A2\u6570\u304B\u3089\u59CB\u307E\u308A\u307E\u3059\u3002"
    bounce: 0
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 2
    text: "\u306A\u3093\u3060\u304A\u524D\u305F\u3061\u306F! \u3053\u3053\u304B\u3089\u5148\u306F\u901A\u3055\u306A\u3044\u305E!"
    bounce: 1
    changeVisibility: 1
    showPlayer: 1
    showAssistant: 1
    showEnemy: 1
    enemyIndex: 0
  - speaker: 1
    text: "\u3042\u308C\u306F\u3001\u30B3\u30FC\u30C9\u306E\u66B4\u8D70\u3067\u751F\u307E\u308C\u305F\u3001\u300C\u30B3\u30FC\u30C9\u30A8\u30CD\u30DF\u30FC\u300D\u3067\u3059\u3002\n\u30B3\u30FC\u30C9\u304C\u5B9F\u4F53\u3092\u6210\u3057\u305F\u59FF\u3067\u3001\u5012\u3059\u3068\u30B3\u30FC\u30C9\u3092\u5F97\u308B\u3053\u3068\u304C\u3067\u304D\u307E\u3059\u3002"
    bounce: 0
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
    enemyIndex: 0
  - speaker: 1
    text: "\u305D\u308C\u3067\u306F\u5B9F\u969B\u306B\u3001\u95A2\u6570\u3092\u4F7F\u3063\u3066\u6226\u3063\u3066\u307F\u307E\u3057\u3087\u3046\u3002"
    bounce: 0
    changeVisibility: 0
    showPlayer: 0
    showAssistant: 0
    showEnemy: 0
