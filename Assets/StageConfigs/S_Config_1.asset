  defeatAdvice: "\u30FB\u6575\u306E\u653B\u6483\u4E88\u544A\u3092\u78BA\u8A8D\u3057\u653B\u6483\u304C\u5F53\u305F\u3089\u306A\u3044\u30A8\u30EA\u30A2\u306B\u79FB\u52D5\u3057\u307E\u3057\u3087\u3046\u3002\n\u30FBAP\u306E\u6D88\u8017\u3092\u8003\u3048\u3066\u884C\u52D5\u3057\u307E\u3057\u3087\u3046\u3002"
  tutorialHints:
  - playerTurn: 1
    phase: 0
    message: "\u53F3\u306E\u30B3\u30FC\u30C9\u5165\u529B\u30D5\u30A3\u30FC\u30EB\u30C9\u306B\u3001
      Attack() \u3068\u5165\u529B\u3057\u307E\u3057\u3087\u3046\u3002\u305D\u306E\u5F8C\u3001\u300C\u5B9F\u884C\u300D\u30DC\u30BF\u30F3\u3092\u62BC\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
  - playerTurn: 1
    phase: 1
    message: "\u3053\u308C\u3067\u3001\u4ECA\u5C45\u308B\u30A8\u30EA\u30A2\u5185\u306B\u653B\u6483\u304C\u304D\u307E\u3057\u305F\u306D\u3002\u5DE6\u4E0B\u306EAP\u30B2\u30FC\u30B8\u3092\u898B\u308B\u3068\u3001\u5C11\u3057\u6E1B\u3063\u3066\u3044\u308B\u3053\u3068\u304C\u308F\u304B\u308B\u3088\u601D\u3044\u307E\u3059\u304C\u884C\u52D5\u3059\u308B\u3068AP\u3092\u6D88\u8CBB\u3057\u307E\u3059\u3002\u3069\u3093\u306A\u884C\u52D5\u3092\u3059\u308B\u304B\u306F\u3088\u304F\u8003\u3048\u308B\u5FC5\u8981\u304C\u3042\u308A\u307E\u3059\u306D\u3002\n\u6B21\u306B\u3001\u6575\u306E\u884C\u52D5\u3092\u4E0A\u306E\u300C!\u300D\u30DC\u30BF\u30F3\u304B\u3089\u8AAD\u307F\u3001MoveForward()\u3067\u524D\u306E\u30A8\u30EA\u30A2\u306B\u9032\u3093\u3060\u308A\u3001MoveForward()\u3067\u5F8C\u308D\u306E\u30A8\u30EA\u30A2\u306B\u4E0B\u304C\u3063\u305F\u308A\u3057\u3066\u3001\u6575\u306E\u653B\u6483\u3092\u304B\u308F\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
  - playerTurn: 2
    phase: 0
    message: "\u3044\u3044\u8ABF\u5B50\u3067\u3059\u3002\u4ECA\u5EA6\u306F\u3001\u9B54\u6CD5\u653B\u6483\u3057\u3066\u307F\u307E\u3057\u3087\u3046\u3002Cast(\"\u9B54\u6CD5\u306E\u7A2E\u985E\",
      \u653B\u6483\u3059\u308B\u30A8\u30EA\u30A2\u756A\u53F7) \u3067\u9B54\u6CD5\u653B\u6483\u304C\u3067\u307E\u3059\u3002\n\u307E\u305A\u306F\u3001Cast(\"\u30D5\u30EC\u30A4\u30E0\",
      1)\u3068\u5165\u529B\u3057\u3001\u708E\u9B54\u6CD5\u3067\u30A8\u30EA\u30A21\u306B\u653B\u6483\u3057\u3066\u304F\u3060\u3055\u3044\u3002"
  - playerTurn: 2
    phase: 1
    message: "\u5DE6\u4E0B\u306EAP\u30B2\u30FC\u30B8\u3092\u898B\u308B\u3068\u300120\u6E1B\u3063\u3066\u3044\u307E\u3059\u306D\u3002\u9B54\u6CD5\u306F\u9060\u8DDD\u96E2\u653B\u6483\u304C\u3067\u304D\u308B\u5206\u3001AP\u306E\u6D88\u8CBB\u304C\u6FC0\u3057\u3044\u306E\u3067\u3059\u3002\u9B54\u6CD5\u3092\u4F7F\u3046\u30BF\u30A4\u30DF\u30F3\u30B0\u306F\u3088\u304F\u8003\u3048\u308B\u3068\u3044\u3044\u3067\u3057\u3087\u3046\u3002"
